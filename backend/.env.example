# Backend Environment Example
NODE_ENV=development
PORT=5000

# Supabase Configuration
SUPABASE_URL=https://YOUR-SUPABASE-PROJECT.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# JWT Configuration
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d

# Gemini AI
GEMINI_API_KEY=replace-with-gemini-api-key

# File & Logging
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5000

# Resend Email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Nabeeh <noreply@nabeeh.app>

# Frontend URL (for invite links)
FRONTEND_URL=http://localhost:3000

# Mock data (true to serve mock data without Supabase)
USE_MOCK_DB=false
