# Backend Environment Example
NODE_ENV=development
PORT=5000

# Supabase Configuration
SUPABASE_URL=https://YOUR-SUPABASE-PROJECT.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# JWT Configuration
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d

# Gemini AI
GEMINI_API_KEY=replace-with-gemini-api-key

# WhatsApp / WAHA
WAHA_BASE_URL=http://localhost:3000
WAHA_SESSION_NAME=default
WEBHOOK_URL=http://localhost:5000/api/whatsapp/webhook
WEBHOOK_SECRET=replace-with-webhook-secret
WAHA_SESSION_TIMEOUT=0
WAHA_KEEP_ALIVE_INTERVAL=300000
WAHA_MAX_RECONNECT_ATTEMPTS=3
DISABLE_MONITORING=true

# File & Logging
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
LOG_LEVEL=info
WAHA_LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5000
