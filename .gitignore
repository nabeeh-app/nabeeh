# Nabeeh AI Educational Assistant - .gitignore

# ===========================
# ===== AI AGENT TOOLS =====
# ===========================
.cursorignore
.kiro/
.vscode/

# ===========================
# ===== TEMP / SCRIPTS =====
# ===========================
ralph-loop.sh
ralph-once.sh
ralph-run.log
frontend/ralph-prd.json
frontend/ralph-prompt.txt

# ===========================
# ===== NODE.JS / NPM =====
# ===========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage
.grunt

# Bower dependency directory
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons
build/Release

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# ===========================
# ===== ENVIRONMENT =====
# ===========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.waha
.env.supabase

# ===========================
# ===== REACT / NEXT.JS =====
# ===========================
# Next.js build output
.next/
out/

# React build
build/
dist/

# Storybook build outputs
.out
.storybook-out

# ===========================
# ===== LOGS & DEBUG =====
# ===========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Debug logs
debug.log
error.log
combined.log

# Webhook debug logs
/tmp/webhook_debug.log
webhook_debug.log

# Custom log files
*.log
build.log
simple-recovery.log
whatsapp-recovery.log

# ===========================
# ===== DOCKER & CONTAINERS =====
# ===========================
# Docker volumes and data
docker-data/
volumes/

# ===========================
# ===== OWASP ZAP =====
# ===========================
# ZAP scan reports (generated, don't commit)
zap/reports/
zap/*.json
zap/*.html
zap/*.xml
!zap/zap-config.yaml
!zap/zap-rules.tsv

# ===========================
# ===== WHATSAPP / WAHA =====
# ===========================
# WhatsApp session data (contains sensitive auth info)
sessions/
waha-sessions/
auth_info_baileys/
.sessions/

# WhatsApp media files
media/
.media/

# QR codes (contain sensitive session info)
qr_code*.png
qr-code*.png
*.qr.png

# ===========================
# ===== DATABASE =====
# ===========================
# SQLite databases
*.sqlite
*.sqlite3
*.db

# Database dumps
*.sql
*.dump
!backend/database/*.sql
!database/migrations/*.sql

# ===========================
# ===== AI & API KEYS =====
# ===========================
# API keys and secrets
api-keys.json
secrets.json
credentials.json

# Gemini AI cache
.gemini-cache/

# ===========================
# ===== DEVELOPMENT =====
# ===========================
# IDE and editor files
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ===========================
# ===== TEMPORARY FILES =====
# ===========================
# Temporary directories
tmp/
temp/
.tmp/

# Cache directories
.cache/
.parcel-cache/

# ===========================
# ===== PYTHON (if used) =====
# ===========================
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
ENV/
env/

# ===========================
# ===== TESTING =====
# ===========================
# Test results
test-results/
coverage/
.nyc_output/

# ===========================
# ===== DEPLOYMENT =====
# ===========================
# Production builds
build/
dist/

# Deployment scripts (may contain sensitive info)
deploy.sh
production-deploy.sh

# ===========================
# ===== CUSTOM NABEEH =====
# ===========================
# Backup files
*.backup
*.bak

# Old/test files
*-old.*
*-backup.*
*-test.*

# Documentation drafts
*-draft.md
*-temp.md

# Configuration backups
config-backup/
old-configs/

# ===========================
# ===== SECURITY =====
# ===========================
# Private keys
*.pem
*.key
*.p12
*.pfx

# Certificates
*.crt
*.cer

# JWT secrets
jwt-secret.txt

# ===========================
# ===== MISC =====
# ===========================
# Yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ESLint cache
.eslintcache

# Prettier cache
.prettiercache

# Package manager lock files (keep package-lock.json but ignore yarn.lock if using npm)
# yarn.lock

# Editor directories and files
.vscode/
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?